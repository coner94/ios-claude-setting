{
    "model": "claude-sonnet-4-6",
    "enabledPlugins": {
        "ralph-loop@claude-plugins-official": true
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash(git commit*)",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/scripts/lint.sh",
                        "timeout": 30000
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "if echo \"$TOOL_INPUT\" | grep -q '\\.swift'; then .claude/scripts/build.sh; fi",
                        "timeout": 120000
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [
            "Read",
            "Write",
            "Edit",
            "Glob",
            "Grep",
            "Bash",
            "Agent",
            "Skill"
        ]
    },
    "env": {
        "MAX_OUTPUT_TOKENS": 8000,
        "MAX_THINKING_TOKENS": 10000,
        "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
    }
}
